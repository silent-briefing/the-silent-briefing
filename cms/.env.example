# Copy to `cms/.env`. Adjust for your machine.
#
# Postgres: same database as local Supabase (`supabase start` → port 54322).
# From inside the Directus container, the host is Docker Desktop’s gateway.

DB_CLIENT=pg
DB_HOST=host.docker.internal
DB_PORT=54322
DB_DATABASE=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# Optional: Directus used to document a separate system schema; the app still uses the same DB.
# Leave unset unless you have a reason to change Directus defaults.
# DB_SCHEMA=

# Required in Directus 10+ — encrypts stored secrets. Use ONE stable random string per dev machine.
# If this changes while reusing an existing DB, the app can throw INTERNAL_SERVER_ERROR. After `supabase db reset`,
# a fresh DB + unchanged KEY/SECRET is fine. Generate e.g. `openssl rand -base64 32`.
KEY=replace_with_long_random_string

# JWT / session signing. Keep stable across restarts; rotate only if you understand session invalidation.
SECRET=replace_with_long_random_string

# Used only when the database has NO Directus install yet (first `docker compose up`).
# If you already went through the browser “create admin” / registration flow, ignore these —
# log in with the email + password YOU chose there. Changing these env vars does not reset your password.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password

# Optional: static token for the first admin at bootstrap (automation / scripts). Does not update an existing user.
# ADMIN_TOKEN=

CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000

PUBLIC_URL=http://localhost:8055
PORT=8055

# Hook extension → FastAPI stub
BACKEND_WORKER_URL=http://host.docker.internal:8000
BACKEND_SERVICE_KEY=dev-service-key-change-me

# Optional: for cms/scripts/register-app-collections.ps1 (avoid pasting password on the command line)
# DIRECTUS_EMAIL=
# DIRECTUS_PASSWORD=
# DIRECTUS_ADMIN_TOKEN=
