# Copy to `cms/.env` and adjust. Never commit `cms/.env`.
# Postgres must match `directus_user` in migration `20260419000001_directus_role_grants.sql`.

DB_CLIENT=pg
DB_HOST=host.docker.internal
DB_PORT=54322
DB_DATABASE=postgres
# Local (recommended): Supabase default superuser — avoids Directus 11 bootstrap edge cases with `directus_user`.
DB_USER=postgres
DB_PASSWORD=postgres
# Production-like (migration `20260419000001_directus_role_grants.sql`):
# DB_USER=directus_user
# DB_PASSWORD=changeme_in_env
DB_SCHEMA=directus

SECRET=replace_with_openssl_rand_base64_32
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password

CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000

PUBLIC_URL=http://localhost:8055
PORT=8055

# Hook extension (Task 7) — backend intelligence stub
BACKEND_WORKER_URL=http://host.docker.internal:8000
BACKEND_SERVICE_KEY=dev-service-key-change-me
