# Copy to `.env.local` if you need overrides. Next.js does NOT load this file.
# Default dev vars (incl. Clerk test keys) live in committed `.env.development`.
#
# Clerk (https://dashboard.clerk.com) — Organizations enabled in dashboard
# Dev/test instance keys (rotate for production).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YnJpZ2h0LWtvYWxhLTgyLmNsZXJrLmFjY291bnRzLmRldiQ
CLERK_SECRET_KEY=sk_test_Ilqx0PwotPxVZ6qe8bSuxjWg5655QWGTSb4PJcn0l7

# --- Clerk ↔ Supabase JWT (required for authenticated RLS in the browser) ---
# 1) Local DB: run `supabase status -o env` and copy JWT_SECRET (matches `jwt_secret` in supabase/config.toml).
# 2) Clerk Dashboard → Integrations → Supabase: paste that JWT secret so Clerk signs tokens PostgREST will verify.
# 3) Clerk Dashboard → JWT Templates: create template named `supabase` (claims: sub, aud=authenticated, role, org_id — see CLAUDE.md).
# 4) Leave the line below unset so the app requests the `supabase` template. Use empty/0/false only to silence 404s while the template is missing.
# NEXT_PUBLIC_CLERK_SUPABASE_JWT_TEMPLATE=

# Supabase — after `supabase start`, prefer values from `supabase status -o env` (API_URL + ANON_KEY).
# Use ANON_KEY for NEXT_PUBLIC_SUPABASE_ANON_KEY (legacy JWT anon). PUBLISHABLE_KEY from the CLI is optional for newer flows.
# Dev server falls back to local defaults if these are unset.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# FastAPI BFF (browser calls with Clerk session JWT — see src/lib/bff/client.ts)
NEXT_PUBLIC_BFF_BASE_URL=http://127.0.0.1:8000

# Optional: comma-separated extra hosts for dev HMR when browsing from LAN (see next.config.ts)
# NEXT_PUBLIC_ALLOWED_DEV_ORIGINS=192.168.1.50,10.0.0.5
