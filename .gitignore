# Environment and secrets (never commit real keys)
.env
.env.local
.env.*
!.env.example
cms/.env

# Python / uv
.venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/
.eggs/

# Node / Bun (commit lockfile: bun.lockb or package-lock.json)
node_modules/

# Supabase local
supabase/.branches/
supabase/.temp/

# IDE and OS
.idea/
.vscode/
*.swp
Thumbs.db
.DS_Store

# Logs and coverage
*.log
coverage/
htmlcov/
.coverage

# Directus uploads (large binaries); keep directory in git
cms/uploads/**
!cms/uploads/.gitkeep
